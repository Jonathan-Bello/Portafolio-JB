---
import type { ImageMetadata } from "astro";
import BaseLayout from "./BaseLayout.astro";
import { getLangFromUrl } from "@i18n/utils";
import { Image } from "astro:assets";
import Prose from "./Prose.astro";

interface entry {
  title: string;
  description: string;
  cover: ImageMetadata;
  screenshots?: ImageMetadata[];
  publishDate: Date;
  url?: string;
}

interface Props {
  entry: entry;
}

const { entry } = Astro.props;

const lang = getLangFromUrl(Astro.url);

const formattedDate = new Intl.DateTimeFormat(lang, {
  dateStyle: "long",
}).format(entry.publishDate);

const entryUrl = entry.url ? new URL(entry.url, Astro.url.origin) : undefined;
const isSamePage =
  entryUrl &&
  entryUrl.hostname.includes("jonathanbello.com") &&
  entryUrl.pathname.replace(/\/$/, "") === Astro.url.pathname.replace(/\/$/, "");
const showEntryUrl = entryUrl && !isSamePage;
const entryUrlLabel = lang === "es" ? "Ver sitio publicado" : "View live site";
---

<BaseLayout title={entry.title} description={entry.description} type="article">
  <section class="bg-neutral-100 dark:bg-neutral-950 rounded-2xl py-12 container mb-12">
    <Image
      class="w-full aspect-video object-cover h-96 lg:h-[30rem] xl:h-[36rem] rounded-2xl mb-8"
      src={entry.cover}
      alt={entry.title}
    />
    <h1 class="text-center font-title font-semibold text-4xl lg:text-5xl mb-8">
      {entry.title}
    </h1>

    <p class="text-center font-title text-xl">{formattedDate}</p>
    <p class="max-w-3xl mx-auto mt-4 text-center text-neutral-700 dark:text-neutral-300">
      {entry.description}
    </p>

    {
      showEntryUrl && (
        <div class="mt-6 flex justify-center">
          <a
            href={entryUrl.toString()}
            target="_blank"
            rel="noreferrer"
            class="inline-flex items-center justify-center rounded-lg border border-neutral-300
            bg-neutral-50 px-5 py-2 font-text font-semibold text-neutral-900 transition-colors
            hover:border-neutral-900 hover:bg-neutral-100 dark:border-neutral-700
            dark:bg-neutral-900 dark:text-neutral-100 dark:hover:border-neutral-100
            dark:hover:bg-neutral-800"
          >
            {entryUrlLabel}
          </a>
        </div>
      )
    }
  </section>
  <hr />

  <Prose>
    <slot />

    {
      entry.screenshots && entry.screenshots.length > 0 && (
        <section>
          <div class="grid gap-6">
            {entry.screenshots.map((screenshot) => (
              <Image
                src={screenshot}
                alt={`Captura de ${entry.title}`}
                class="w-full rounded-2xl border border-neutral-200 dark:border-neutral-800"
              />
            ))}
          </div>
        </section>
      )
    }
  </Prose>

  <slot name="footer" />
</BaseLayout>
