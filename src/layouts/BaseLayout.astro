---
import "../styles/global.css";
import Footer from "./Footer.astro";
import Header from "./Header.astro";
import { getLangFromUrl } from "../i18n/utils";
import { SEO } from "astro-seo";
import { ClientRouter } from "astro:transitions";

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  noindex?: boolean;
}

const {
  title,
  description = "Jonathan Alexis Bello López - Fullstack Developer con enfoque Frontend, 4 años de experiencia, liderazgo técnico, educación e inteligencia artificial aplicada.",
  image = "/lettermark-dark.svg",
  type = "website",
  noindex = false,
} = Astro.props;

const lang = getLangFromUrl(Astro.url);
const siteTitle = `${title} | Jonathan Bello`;
const canonical = new URL(
  Astro.url.pathname,
  Astro.site ?? Astro.url.origin,
).toString();

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Jonathan Alexis Bello López",
  url: "https://jonathanbello.com",
  jobTitle: "Fullstack Developer",
  email: "mailto:contacto@jonathanbello.com",
  address: {
    "@type": "PostalAddress",
    addressCountry: "MX",
  },
  sameAs: [
    "https://www.instagram.com/jonathanbe110/",
    "https://x.com/Jonathan_Be110",
    "https://www.facebook.com/JonathanBe110",
    "https://www.linkedin.com/in/jonathan-alexis-bello/",
    "https://github.com/Jonathan-Bello",
  ],
  knowsAbout: [
    "Astro.js",
    "Tailwind CSS",
    "Frontend Development",
    "Technical SEO",
    "Artificial Intelligence",
    "Educational Video Games",
  ],
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <link rel="canonical" href={canonical} />
    <script is:inline>
      try {
        const savedTheme = localStorage.getItem("theme");
        const prefersDark = window.matchMedia(
          "(prefers-color-scheme: dark)",
        ).matches;
        const shouldUseDark =
          savedTheme === "dark" || (!savedTheme && prefersDark);
        document.documentElement.classList.toggle("dark", shouldUseDark);
      } catch {
        document.documentElement.classList.remove("dark");
      }
    </script>
    <link
      rel="icon"
      type="image/svg+xml"
      href="/lettermark.svg"
      media="(prefers-color-scheme: light)"
    />
    <link
      rel="icon"
      type="image/svg+xml"
      href="/lettermark-dark.svg"
      media="(prefers-color-scheme: dark)"
    />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap"
      rel="stylesheet"
    />
    <title>{siteTitle}</title>

    <SEO
      title={siteTitle}
      description={description}
      openGraph={{
        basic: {
          title: siteTitle,
          type,
          image,
          url: canonical,
        },
        optional: {
          description,
          locale: lang === "es" ? "es_MX" : "en_US",
          siteName: "Jonathan Bello",
        },
      }}
      twitter={{
        card: "summary_large_image",
        site: "@Jonathan_Be110",
        creator: "@Jonathan_Be110",
        title: siteTitle,
        description,
        image,
      }}
    />
    <script
      type="application/ld+json"
      set:html={JSON.stringify(personSchema)}
    />

    <script is:inline src="https://www.google.com/recaptcha/api.js"></script>

    <ClientRouter />
  </head>
  <body
    class="flex flex-col min-h-screen bg-neutral-50 dark:bg-neutral-800 dark:text-neutral-100"
  >
    <Header />
    <main class="flex-1 w-full mx-auto pt-16 flex flex-col items-center">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>

<script is:inline>
  function updateFavicon() {
    const isDark = document.documentElement.classList.contains("dark");
    const faviconLink = document.querySelector('link[rel="icon"]');

    if (faviconLink) {
      faviconLink.href = isDark ? "/lettermark-dark.svg" : "/lettermark.svg";
    }
  }

  updateFavicon();
  window.addEventListener("theme-change", updateFavicon);
</script>
