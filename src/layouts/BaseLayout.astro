---
import "../styles/global.css";
import Footer from "./Footer.astro";
import Header from "./Header.astro";
import { getLangFromUrl } from "../i18n/utils";
import { ClientRouter } from "astro:transitions";

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  noindex?: boolean;
}

const {
  title,
  description = `Jonathan Alexis Bello L${String.fromCharCode(243)}pez - Fullstack Developer con enfoque Frontend, 4 a${String.fromCharCode(241)}os de experiencia, liderazgo t${String.fromCharCode(233)}cnico, educaci${String.fromCharCode(243)}n e inteligencia artificial aplicada.`,
  image = "/lettermark-dark.svg",
  type = "website",
  noindex = false,
} = Astro.props;

const lang = getLangFromUrl(Astro.url);
const site = Astro.site ?? new URL("https://jonathanbello.com");
const normalizedPath =
  Astro.url.pathname === "/" || Astro.url.pathname.endsWith("/")
    ? Astro.url.pathname
    : `${Astro.url.pathname}/`;
const siteTitle =
  normalizedPath === "/"
    ? `Jonathan Alexis Bello L${String.fromCharCode(243)}pez | Desarrollador Web Fullstack Frontend`
    : `${title}${lang === "en" ? " | Jonathan Bello EN" : " | Jonathan Bello"}`;
const canonical = new URL(normalizedPath, site).toString();
const absoluteImage = new URL(image, site).toString();
const shouldNoindex = noindex || Astro.url.searchParams.size > 0;
const trimAtWord = (value: string, maxLength: number) => {
  const normalized = value.replace(/\s+/g, " ").trim();
  if (normalized.length <= maxLength) return normalized;
  const shortened = normalized.slice(0, maxLength - 3).replace(/\s+\S*$/, "").trim();
  return `${shortened}...`;
};
const metaDescription = trimAtWord(description, 155);
const boundedSiteTitle = trimAtWord(siteTitle, 55);
const staticHreflangPaths = new Set([
  "/",
  "/about/",
  "/blog/",
  "/contact/",
  "/projects/",
  "/en/",
  "/en/about/",
  "/en/blog/",
  "/en/contact/",
  "/en/projects/",
]);
const esPath = normalizedPath.startsWith("/en")
  ? normalizedPath.replace(/^\/en/, "") || "/"
  : normalizedPath;
const enPath = normalizedPath.startsWith("/en")
  ? normalizedPath
  : `/en${normalizedPath === "/" ? "/" : normalizedPath}`;
const alternateLinks = staticHreflangPaths.has(normalizedPath)
  ? [
      { lang: "es-MX", href: new URL(esPath, site).toString() },
      { lang: "en", href: new URL(enPath, site).toString() },
      { lang: "x-default", href: new URL(esPath, site).toString() },
    ]
  : [];

const personSchema = {
  "@type": "Person",
  "@id": "https://jonathanbello.com/#person",
  name: `Jonathan Alexis Bello L${String.fromCharCode(243)}pez`,
  alternateName: [
    "Jonathan Bello",
    `Jonathan Bello L${String.fromCharCode(243)}pez`,
    `Jonathan Alex Bello L${String.fromCharCode(243)}pez`,
    `Jonathan X. Bello L${String.fromCharCode(243)}pez`,
  ],
  url: "https://jonathanbello.com",
  jobTitle: "Fullstack Developer",
  email: "mailto:contacto@jonatan.com",
  image: new URL("/lettermark-dark.svg", site).toString(),
  address: {
    "@type": "PostalAddress",
    addressCountry: "MX",
  },
  alumniOf: {
    "@type": "CollegeOrUniversity",
    name: `Instituto Tecnol${String.fromCharCode(243)}gico Superior de Teziutl${String.fromCharCode(225)}n`,
  },
  affiliation: [
    {
      "@type": "Organization",
      name: "EDteam",
      url: "https://ed.team",
    },
    {
      "@type": "Organization",
      name: "YGU COMUNICAXION",
    },
    {
      "@type": "Organization",
      name: "AppDeux",
    },
    {
      "@type": "CollegeOrUniversity",
      name: `Instituto Tecnol${String.fromCharCode(243)}gico Superior de Teziutl${String.fromCharCode(225)}n`,
    },
  ],
  sameAs: [
    "https://www.instagram.com/jonathanbe110/",
    "https://x.com/Jonathan_Be110",
    "https://www.facebook.com/JonathanBe110/",
    "https://www.linkedin.com/in/jonathan-alexis-bello/",
    "https://github.com/Jonathan-Bello",
  ],
  knowsAbout: [
    "Astro.js",
    "Tailwind CSS",
    "Frontend Development",
    "Technical SEO",
    "Artificial Intelligence",
    "Educational Video Games",
  ],
};

const websiteSchema = {
  "@type": "WebSite",
  "@id": "https://jonathanbello.com/#website",
  url: "https://jonathanbello.com",
  name: "Jonathan Bello",
  alternateName: `Jonathan Alexis Bello L${String.fromCharCode(243)}pez`,
  inLanguage: ["es-MX", "en"],
  publisher: {
    "@id": "https://jonathanbello.com/#person",
  },
};

const schema = {
  "@context": "https://schema.org",
  "@graph": [personSchema, websiteSchema],
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{boundedSiteTitle}</title>
    <meta name="description" content={metaDescription} />
    <meta
      name="robots"
      content={shouldNoindex ? "noindex,nofollow" : "index,follow"}
    />
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    {
      alternateLinks.map((alternate) => (
        <link
          rel="alternate"
          hreflang={alternate.lang}
          href={alternate.href}
        />
      ))
    }
    <meta property="og:title" content={boundedSiteTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={absoluteImage} />
    <meta property="og:locale" content={lang === "es" ? "es_MX" : "en_US"} />
    <meta property="og:site_name" content="Jonathan Bello" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@Jonathan_Be110" />
    <meta name="twitter:creator" content="@Jonathan_Be110" />
    <meta name="twitter:title" content={boundedSiteTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={absoluteImage} />
    <script is:inline>
      function applyStoredTheme() {
        const savedTheme = localStorage.getItem("theme");
        document.documentElement.classList.toggle("dark", savedTheme === "dark");
      }

      try {
        applyStoredTheme();

        document.addEventListener("astro:before-swap", (event) => {
          event.newDocument.documentElement.classList.toggle(
            "dark",
            document.documentElement.classList.contains("dark"),
          );
        });

        document.addEventListener("astro:page-load", applyStoredTheme);
      } catch {
        document.documentElement.classList.remove("dark");
      }
    </script>
    <link
      rel="icon"
      type="image/svg+xml"
      href="/lettermark.svg"
      media="(prefers-color-scheme: light)"
    />
    <link
      rel="icon"
      type="image/svg+xml"
      href="/lettermark-dark.svg"
      media="(prefers-color-scheme: dark)"
    />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="32x32" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=optional"
      rel="stylesheet"
    />
    <script
      type="application/ld+json"
      set:html={JSON.stringify(schema)}
    />

    <ClientRouter />
  </head>
  <body
    class="flex flex-col min-h-screen bg-neutral-50 dark:bg-neutral-800 dark:text-neutral-100"
  >
    <Header />
    <main class="flex-1 w-full mx-auto pt-16 flex flex-col items-center">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>

<script is:inline>
  function updateFavicon() {
    const isDark = document.documentElement.classList.contains("dark");
    const faviconLink = document.querySelector('link[rel="icon"]');

    if (faviconLink) {
      faviconLink.href = isDark ? "/lettermark-dark.svg" : "/lettermark.svg";
    }
  }

  updateFavicon();
  window.addEventListener("theme-change", updateFavicon);
  document.addEventListener("astro:page-load", updateFavicon);
</script>
