---
import ContentListingLayout from "@components/pages/shared/ContentListingLayout.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import {
  AcademicCapIcon,
  BookOpenIcon,
  CodeBracketIcon,
  HeartIcon,
  PuzzlePieceIcon,
  SparklesIcon,
} from "@heroicons/react/24/outline";
import {
  getLangFromUrl,
  useTranslations,
  useTranslatedPath,
} from "@i18n/utils";

export const prerender = true;

export async function getStaticPaths() {
  const categories = await getCollection("categories");

  return categories.map((category) => ({
    params: { category: category.data.id },
  }));
}

const { category } = Astro.params;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const categories = await getCollection("categories");
const currentCategory = categories.find((item) => item.data.id === category);
const navCategories = categories.map((category) => ({
  id: category.data.id,
  name: category.data.name,
  href: translatePath(`/blogs/categories/${category.data.id}`),
}));

if (!currentCategory || !category) {
  return Astro.redirect("/404/");
}

const filterPosts = await getCollection(
  "blogs",
  ({ id, data }) => id.startsWith(lang) && data.category.id === category,
);

const categoryIcons = {
  educacion: AcademicCapIcon,
  ia: SparklesIcon,
  salud: HeartIcon,
  tech: CodeBracketIcon,
  videojuegos: PuzzlePieceIcon,
  vida: BookOpenIcon,
};
---

<BaseLayout
  title={`Blog: ${currentCategory.data.name} | Español`}
  description={`Artículos de Jonathan Bello en ${currentCategory.data.name}: desarrollo web, educación, inteligencia artificial, videojuegos y marca personal.`}
>
  <ContentListingLayout
    title={`Blog: ${currentCategory.data.name}`}
    description={currentCategory.data.name}
    categoryTitle={t("blog.categories.title")}
    categoryAllLabel={t("blog.categories.all")}
    categoryAllHref={translatePath("/blog")}
    categories={navCategories}
    activeCategory={category}
  >
    {
      filterPosts.map((blog) => {
        const category = categories.find(
          (category) => category.data.id === blog.data.category.id,
        );
        const Icon =
          categoryIcons[blog.data.category.id as keyof typeof categoryIcons] ??
          BookOpenIcon;

        return (
          <article class="flex flex-col bg-neutral-50 dark:bg-neutral-900 shadow-lg rounded-lg overflow-hidden transition-transform transform hover:scale-105">
            <a
              href={translatePath(`/blogs/${blog.id.replace(`${lang}/`, "")}`)}
              class="flex flex-col h-full"
            >
              <Image
                src={blog.data.cover}
                alt={blog.data.title}
                transition:name={`blog-cover-${blog.id.replace(`${lang}/`, "")}`}
                class="w-full h-48 object-cover rounded-t-lg"
              />
              <div class="p-4 flex-1">
                <h2 class="font-title text-lg font-semibold text-neutral-900 dark:text-neutral-100 line-clamp-2">
                  {blog.data.title}
                </h2>
                <p class="text-neutral-700 dark:text-neutral-300 mt-2 line-clamp-3">
                  {blog.data.description}
                </p>
              </div>

              <div class="p-4 bg-neutral-100 dark:bg-neutral-800 rounded-b-lg">
                <h3 class="inline-flex items-center gap-2 font-title text-sm font-semibold text-neutral-800 dark:text-neutral-100">
                  <Icon className="size-4 text-neutral-500 dark:text-neutral-400" />
                  {category?.data.name}
                </h3>
              </div>
            </a>
          </article>
        );
      })
    }
  </ContentListingLayout>
</BaseLayout>
