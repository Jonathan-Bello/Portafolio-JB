---
import ProjectPage from "@components/pages/ProjectPage.astro";
import { getCollection, getEntry, render } from "astro:content";

export const prerender = true;

export async function getStaticPaths() {
  const projects = await getCollection("projects", ({ id }) =>
    id.startsWith("es/"),
  );

  return projects
    .filter((project) => project.data.isVisible !== false)
    .map((project) => ({
      params: { slug: project.id.replace("es/", "") },
    }));
}

const { slug } = Astro.params;

const project = await getEntry("projects", `es/${slug}`);

if (!project || project.data.isVisible === false) {
  return Astro.redirect("/404/");
}

const { Content, headings } = await render(project);
---

<ProjectPage project={project}>
  <Content />
</ProjectPage>
