---
import ProjectsPage from "@components/pages/ProjectsPage.astro";
import BaseLayout from "@layouts/BaseLayout.astro";

import { getCollection } from "astro:content";

import {
  getLangFromUrl,
} from "@i18n/utils";

export const prerender = true;

export async function getStaticPaths() {
  const categories = await getCollection("categoriesProjects");

  return categories.map((category) => ({
    params: { category: category.data.id },
  }));
}

const lang = getLangFromUrl(Astro.url);

const { category } = Astro.params;
const categories = await getCollection("categoriesProjects");

if (!categories.find((cat) => cat.data.id === category)) {
  return Astro.redirect("/404/");
}

const allProjects = await getCollection("projects", ({ id }) => {
  return id.startsWith(lang);
});

const projects = allProjects.filter((project) =>
  project.data.category.find((cat) => cat.id === category)
);
---

<BaseLayout
  title={`Proyectos ${category}`}
  description={`Proyectos de Jonathan Bello en la categoría ${category}: desarrollo web, frontend, educación, IA y soluciones digitales.`}
>
  <ProjectsPage projects={projects} activeCategory={category} />
</BaseLayout>
