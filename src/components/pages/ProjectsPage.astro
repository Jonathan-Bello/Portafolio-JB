---
import { getCollection } from "astro:content";
import ContentListingLayout from "@components/pages/shared/ContentListingLayout.astro";

import {
  getLangFromUrl,
  useTranslations,
  useTranslatedPath,
} from "@i18n/utils";
import type { CollectionEntry } from "astro:content";
import ProjectCard from "@components/cards/ProjectCard.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const categories = await getCollection("categoriesProjects");
const getCategoryName = (category: (typeof categories)[number]) =>
  lang === "es" ? category.data.nameEs : category.data.nameEn;
const navCategories = categories.map((category) => ({
  id: category.data.id,
  name: getCategoryName(category),
  href: translatePath(`/projects/category/${category.data.id}`),
}));

// Pasamos los proyectos de forma dinamica.
interface Props {
  projects: CollectionEntry<"projects">[];
  activeCategory?: string;
}

const { projects, activeCategory } = Astro.props;
---

<ContentListingLayout
  title={t("projects.banner.title")}
  description={t("projects.banner.description")}
  categoryTitle={t("projects.categories.title")}
  categoryAllLabel={t("projects.categories.all")}
  categoryAllHref={translatePath("/projects")}
  categories={navCategories}
  activeCategory={activeCategory}
>
  {projects.map((project) => <ProjectCard project={project} />)}
</ContentListingLayout>
