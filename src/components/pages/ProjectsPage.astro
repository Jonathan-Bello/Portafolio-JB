---
import { getCollection } from "astro:content";
import ContentListingLayout from "@components/pages/shared/ContentListingLayout.astro";

import {
  getLangFromUrl,
  useTranslations,
  useTranslatedPath,
} from "@i18n/utils";
import type { CollectionEntry } from "astro:content";
import ProjectCard from "@components/cards/ProjectCard.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const categories = await getCollection("categoriesProjects");
const getCategoryName = (category: (typeof categories)[number]) =>
  lang === "es" ? category.data.nameEs : category.data.nameEn;
const navCategories = categories.map((category) => ({
  id: category.data.id,
  name: getCategoryName(category),
  href: translatePath(`/projects/category/${category.data.id}`),
}));

// Pasamos los proyectos de forma dinamica.
interface Props {
  projects: CollectionEntry<"projects">[];
  activeCategory?: string;
}

const { projects, activeCategory } = Astro.props;

const sortedProjects = [...projects].sort((a, b) => {
  return (
    new Date(b.data.publishDate).getTime() -
    new Date(a.data.publishDate).getTime()
  );
});
---

<ContentListingLayout
  title={t("projects.banner.title")}
  description={t("projects.banner.description")}
  categoryTitle={t("projects.categories.title")}
  categoryAllLabel={t("projects.categories.all")}
  categoryAllHref={translatePath("/projects")}
  categories={navCategories}
  activeCategory={activeCategory}
>
  <div
    class="md:col-span-2 lg:col-span-3 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3
    rounded-lg border border-neutral-200 dark:border-neutral-800 bg-white dark:bg-neutral-950 px-4 py-3"
  >
    <p class="font-title font-semibold text-neutral-950 dark:text-neutral-100">
      {t("projects.sort.label")}
    </p>
    <div
      data-project-sort-controls
      class="inline-flex w-full sm:w-auto rounded-lg border border-neutral-200 dark:border-neutral-800 overflow-hidden"
      aria-label={t("projects.sort.label")}
    >
      <button
        type="button"
        data-project-sort="date"
        aria-pressed="true"
        class="flex-1 sm:flex-none px-4 py-2 text-center text-sm font-semibold transition-colors hover:cursor-pointer
        bg-neutral-950 text-white hover:bg-neutral-800 dark:bg-neutral-100 dark:text-neutral-950 dark:hover:bg-neutral-200"
      >
        {t("projects.sort.date")}
      </button>
      <button
        type="button"
        data-project-sort="az"
        aria-pressed="false"
        class="flex-1 sm:flex-none px-4 py-2 text-center text-sm font-semibold transition-colors hover:cursor-pointer
        border-l border-neutral-200 text-neutral-700 hover:bg-neutral-100
        dark:border-neutral-800 dark:text-neutral-300 dark:hover:bg-neutral-900"
      >
        {t("projects.sort.az")}
      </button>
    </div>
  </div>

  <div data-project-grid class="contents">
    {sortedProjects.map((project) => <ProjectCard project={project} />)}
  </div>
</ContentListingLayout>

<script>
  function initProjectSort() {
    const controls = document.querySelector("[data-project-sort-controls]");
    const grid = document.querySelector("[data-project-grid]");

    if (!(controls instanceof HTMLElement) || !(grid instanceof HTMLElement)) {
      return;
    }

    const buttons = Array.from(
      controls.querySelectorAll("[data-project-sort]"),
    ).filter(
      (button): button is HTMLButtonElement =>
        button instanceof HTMLButtonElement,
    );

    const cards = Array.from(
      grid.querySelectorAll("[data-project-card]"),
    ).filter((card): card is HTMLElement => card instanceof HTMLElement);

    const setActiveButton = (activeSort: string) => {
      buttons.forEach((button) => {
        const isActive = button.dataset.projectSort === activeSort;
        button.setAttribute("aria-pressed", isActive ? "true" : "false");
        button.classList.toggle("bg-neutral-950", isActive);
        button.classList.toggle("text-white", isActive);
        button.classList.toggle("dark:bg-neutral-100", isActive);
        button.classList.toggle("dark:text-neutral-950", isActive);
        button.classList.toggle("text-neutral-700", !isActive);
        button.classList.toggle("dark:text-neutral-300", !isActive);
        button.classList.toggle("hover:bg-neutral-800", isActive);
        button.classList.toggle("dark:hover:bg-neutral-200", isActive);
        button.classList.toggle("hover:bg-neutral-100", !isActive);
        button.classList.toggle("dark:hover:bg-neutral-900", !isActive);
      });
    };

    const sortCards = (sort: string) => {
      const sortedCards = [...cards].sort((a, b) => {
        if (sort === "az") {
          return (a.dataset.projectTitle ?? "").localeCompare(
            b.dataset.projectTitle ?? "",
            document.documentElement.lang || "es",
          );
        }

        return (
          Date.parse(b.dataset.projectDate ?? "") -
          Date.parse(a.dataset.projectDate ?? "")
        );
      });

      sortedCards.forEach((card) => grid.appendChild(card));
      setActiveButton(sort);
    };

    buttons.forEach((button) => {
      if (button.dataset.bound === "true") return;
      button.dataset.bound = "true";
      button.addEventListener("click", () => {
        sortCards(button.dataset.projectSort ?? "date");
      });
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initProjectSort);
  } else {
    initProjectSort();
  }

  document.addEventListener("astro:page-load", initProjectSort);
</script>
