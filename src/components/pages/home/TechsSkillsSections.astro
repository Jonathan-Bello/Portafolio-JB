---
import TechCard from "@components/cards/TechCard.astro";
import { getLangFromUrl, useTranslations } from "@i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

import svgCSS from "@assets/logos/logoCSS.svg";
import svgTailwind from "@assets/logos/logoTailwind.svg";
import svgAstro from "@assets/logos/logoAstro.svg";
import svgReact from "@assets/logos/logoReact.svg";
import svgGatsby from "@assets/logos/logoGatsby.svg";
import svgWordpress from "@assets/logos/logoWordpress.svg";
import svgHTMLCanvas from "@assets/logos/logoHTMLCanvas.svg";
import svgSVG from "@assets/logos/logoSvg.svg";
import svgGodot from "@assets/logos/logoGodot.svg";
import svgStripe from "@assets/logos/logoStripe.svg";
import svgGolang from "@assets/logos/logoGolang-gopher.svg";
import svgNode from "@assets/logos/logoNode.svg";
import svgNext from "@assets/logos/logoNext.svg";
import svgCloudflare from "@assets/logos/logoCloudflare.svg";
import svgUI from "@assets/logos/logoUI.svg";
import svgFigma from "@assets/logos/logoFigma.svg";
import svgVector from "@assets/logos/logoVector.svg";
import svgVSCode from "@assets/logos/logoVSC.svg";
import svgGit from "@assets/logos/logoGit.svg";
import svgGithub from "@assets/logos/logoGithub.svg";
import svgTerminal from "@assets/logos/logoGnu_bash.svg";
import svgAsana from "@assets/logos/logoAsana.svg";
import svgNotion from "@assets/logos/logoNotion.svg";
import svgMarkdown from "@assets/logos/logoMarkdown.svg";
---

<section class="container px-4 lg:px-0 mb-16">
  <h2
    class="text-center font-title font-semibold text-2xl lg:text-4xl lg:text-[40px] mb-6 lg:mb-10"
  >
    {t("home.techs.title")}
  </h2>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 md:gap-12">
    <div class="flex flex-col items-center">
      <h3 class="w-full max-w-[368px] text-start font-title font-semibold text-xl mb-6">
        {t("home.techs.titleFrontend")}
      </h3>

      <div class="grid grid-cols-3 lg:grid-cols-3 gap-4">
        <TechCard title="Astro" img={svgAstro} />
        <TechCard title="Tailwind CSS" img={svgTailwind} />
        <TechCard title="Go" img={svgGolang} />
        <TechCard title="Figma" img={svgFigma} />
        <TechCard title="Godot" img={svgGodot} />
        <TechCard title="SEO técnico" img={svgCloudflare} />
      </div>
    </div>

    <div class="flex flex-col items-center">
      <h3 class="w-full max-w-[368px] text-start font-title font-semibold text-xl mb-6">
        {t("home.techs.titleBackend")}
      </h3>

      <div class="grid grid-cols-3 lg:grid-cols-3 gap-4">
        <TechCard title="React" img={svgReact} />
        <TechCard title="Next.js" img={svgNext} />
        <TechCard title="Node.js" img={svgNode} />
        <TechCard title="Gatsby" img={svgGatsby} />
        <TechCard title="WordPress" img={svgWordpress} />
        <TechCard title="Stripe / PayPal" img={svgStripe} />
      </div>
    </div>

    <div class="flex flex-col items-center">
      <h3 class="w-full max-w-[368px] text-start font-title font-semibold text-xl mb-6">
        {t("home.techs.titleUi")}
      </h3>

      <div class="grid grid-cols-3 lg:grid-cols-3 gap-4">
        <TechCard title="UI" img={svgUI} />
        <TechCard title="Figma" img={svgFigma} />
        <TechCard title="Vector" img={svgVector} />
        <TechCard title="SVG" img={svgSVG} />
        <TechCard title="HTML Canvas" img={svgHTMLCanvas} />
        <TechCard title="Prototipado" img={svgNotion} />
      </div>
    </div>

    <div class="flex flex-col items-center">
      <h3 class="w-full max-w-[368px] text-start font-title font-semibold text-xl mb-6">
        {t("home.techs.titleDevelopmentTools")}
      </h3>

      <div class="grid grid-cols-3 lg:grid-cols-3 gap-4">
        <TechCard title="IA aplicada" img={svgTerminal} />
        <TechCard title="LLMs" img={svgMarkdown} />
        <TechCard title="Wallace CSS" img={svgCSS} />
        <TechCard title="Git" img={svgGit} />
        <TechCard title="Github" img={svgGithub} />
        <TechCard title="Asana / Notion" img={svgAsana} />
        <TechCard title="VSCode" img={svgVSCode} />
      </div>
    </div>
  </div>
</section>
