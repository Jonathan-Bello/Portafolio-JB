---
import {
  AcademicCapIcon,
  CodeBracketIcon,
  ComputerDesktopIcon,
  DevicePhoneMobileIcon,
  PuzzlePieceIcon,
  ServerIcon,
  SparklesIcon,
  SwatchIcon,
} from "@heroicons/react/24/outline";

import { getLangFromUrl, useTranslatedPath } from "@i18n/utils";

const lang = getLangFromUrl(Astro.url);
const translatePath = useTranslatedPath(lang);

const categoriesIcons = {
  web: ComputerDesktopIcon,
  mobile: DevicePhoneMobileIcon,
  backend: ServerIcon,
  games: PuzzlePieceIcon,
  ui: SwatchIcon,
  education: AcademicCapIcon,
  ai: SparklesIcon,
};

type Props = {
  id: string;
  title: string;
  link: string;
};

const { id, title, link } = Astro.props;
const iconKey = id.toLowerCase().replace(/\s+/g, "") as keyof typeof categoriesIcons;
const Icon = categoriesIcons[iconKey] ?? CodeBracketIcon;
---

<a
  href={translatePath(link)}
  class="inline-flex w-fit max-w-56 items-center gap-3 rounded-lg border border-neutral-200
  bg-neutral-50 px-4 py-2 font-text font-medium text-neutral-800 transition-colors
  hover:border-neutral-400 hover:bg-neutral-100 dark:border-neutral-800
  dark:bg-neutral-900 dark:text-neutral-200 dark:hover:border-neutral-600
  dark:hover:bg-neutral-800"
>
  <Icon className="size-5 shrink-0 text-neutral-500 dark:text-neutral-400" />
  <span>{title}</span>
</a>
